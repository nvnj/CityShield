# Google / Gemini (ADC — no API key needed)
GOOGLE_CLOUD_PROJECT=cityshield-hackathon
GOOGLE_CLOUD_LOCATION=us
GEMINI_MODEL=gemini-2.5-flash

# Elastic
ELASTIC_URL=https://your-deployment.us-central1.gcp.cloud.es.io:443
ELASTIC_API_KEY=your_elastic_api_key

# App config
ASSESSMENT_WINDOW_MINUTES=5
SURGE_DENSITY_THRESHOLD=0.75
SENTIMENT_ALERT_THRESHOLD=-0.5
